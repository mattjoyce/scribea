## Blobs (content-addressed audio store)
blobs/

## SQLite
*.db
*.db-wal
*.db-shm
*.db-journal

## Build artifacts
/bin/
/ingress/scribe-ingress
/ingress/ingress
/ingress/bin/
/pwa/dist/
/pwa/node_modules/

## Test corpus — text + ground-truth JSON live in the repo, audio does
## not. Per docs/scribe-test-corpus.md §9, background MP3s + rendered
## clip WAVs live in an external pool dir (SCRIBE_CORPUS_AUDIO_DIR).
## These patterns are defensive — they keep audio out even if a render
## script writes it into the working tree by mistake.
corpus/**/*.mp3
corpus/**/*.wav
corpus/**/*.flac
corpus/**/*.m4a
corpus/**/*.ogg
corpus/**/*.aiff
corpus/**/*.aac
corpus/**/*.inflight
corpus/**/*.tmp

## Logs
*.log
logs/

## Env
.env
.env.local

## OS
.DS_Store
Thumbs.db

## Editor
.idea/
.vscode/
*.swp
*~

## Python (plugin venvs)
plugins/**/__pycache__/
plugins/**/.venv/
plugins/**/*.pyc

## Go
ingress/vendor/

## Beads
.beads/*.db
.beads/*.db-wal
.beads/*.db-shm

## test-corpus audio (the scribe-test-corpus.md v0 design uses this layout)
test-corpus/**/clips/*.mp3
test-corpus/backgrounds/*.mp3
test-corpus/.cache/
