{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scribea:soap_consult/1.0.0",
  "title": "SOAP consult note",
  "type": "object",
  "additionalProperties": false,
  "required": ["subjective", "objective", "assessment", "plan"],
  "properties": {
    "subjective": {
      "type": "string",
      "minLength": 1,
      "description": "Patient-reported history and symptoms."
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "description": "Observed or measured findings."
    },
    "assessment": {
      "type": "string",
      "minLength": 1,
      "description": "Clinician's working diagnosis or framing."
    },
    "plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Ordered list of next-step actions."
    }
  }
}
